# =========================
# Kafka
# =========================
KAFKA_BROKERS=localhost:9092 # Comma-separated Kafka bootstrap servers
KAFKA_SECURITY_PROTOCOL=SASL_SSL # PLAINTEXT for local only, SASL_SSL for staging/prod
KAFKA_SASL_MECHANISM=PLAIN # Kafka auth mechanism
KAFKA_USERNAME=your_kafka_username # Kafka SASL username
KAFKA_PASSWORD=your_kafka_password # Kafka SASL password/secret
KAFKA_TOPIC_RAW_EVENTS=raw.events # Topic for unprocessed connector payloads
KAFKA_TOPIC_NORMALIZED_EVENTS=normalized.events # Topic for normalized/enriched records
KAFKA_TOPIC_EMBEDDING_JOBS=embedding.jobs # Topic consumed by vectorizer workers
KAFKA_TOPIC_DLQ=dead.letter.queue # Topic for failed events

# =========================
# PostgreSQL
# =========================
DATABASE_URL=postgresql+asyncpg://pipeline_user:change_me@localhost:5432/pipeline_db # Async SQLAlchemy DSN
POSTGRES_POOL_MIN_SIZE=5 # Minimum DB connection pool size
POSTGRES_POOL_MAX_SIZE=20 # Maximum DB connection pool size

# =========================
# Qdrant
# =========================
QDRANT_URL=http://localhost:6333 # Qdrant base URL
QDRANT_API_KEY=your_qdrant_api_key # Optional for local, required in secured envs
QDRANT_COLLECTION=pipeline_docs # Default vector collection name

# =========================
# Redis
# =========================
REDIS_URL=redis://localhost:6379/0 # Redis URL for dedup/cache/counters
REDIS_DB=0 # Redis logical database index

# =========================
# LLM APIs
# =========================
GROQ_API_KEY=your_groq_api_key # Groq API key for classify/extract/summarize
GROQ_CLASSIFY_MODEL=llama-3.1-8b-instant # Fast classifier model
GROQ_EXTRACT_MODEL=llama-3.3-70b-versatile # Higher-quality extraction model
LLM_REQUEST_TIMEOUT_SECONDS=30 # Timeout for LLM API calls

# =========================
# Data Source APIs
# =========================
NEWS_API_KEY=your_news_api_key # NewsAPI key
GITHUB_TOKEN=your_github_personal_access_token # GitHub token for higher rate limits
SEC_USER_AGENT=YourCompany contact@company.com # Required SEC EDGAR user-agent
GITHUB_API_BASE_URL=https://api.github.com # Base GitHub API URL

# =========================
# Composio
# =========================
COMPOSIO_API_KEY=your_composio_api_key # Composio platform key
COMPOSIO_WEBHOOK_SECRET=your_composio_webhook_secret # Verify inbound Composio webhooks

# =========================
# App Config
# =========================
PIPELINE_API_KEY=your_internal_pipeline_api_key # Internal API authentication key
LOG_LEVEL=INFO # DEBUG|INFO|WARNING|ERROR|CRITICAL
ENVIRONMENT=development # development|staging|production
APP_HOST=0.0.0.0 # API bind host
APP_PORT=8080 # API bind port
METRICS_PORT=9090 # Prometheus metrics port
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173 # Comma-separated allowed frontend origins
